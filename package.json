{
  "name": "board-ai",
  "version": "0.1.0",
  "private": true,
  "description": "A realtime voice-driven Excalidraw workspace powered by Pi agents.",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "concurrently --kill-others --names backend,web \"tsx watch src/server/index.ts\" \"vite --config vite.browser.config.ts\"",
    "dev:web:backend": "tsx watch src/server/index.ts",
    "dev:web:frontend": "vite --config vite.browser.config.ts",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:landing": "node scripts/e2e-landing-page.mjs",
    "start": "electron-vite preview",
    "package:mac": "npm run build && electron-builder --mac dmg --arm64"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@excalidraw/excalidraw": "0.18.1",
    "@openai/agents": "0.13.5",
    "dotenv": "^17.4.2",
    "elkjs": "0.11.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/fontkit": "^2.0.9",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "concurrently": "^10.0.3",
    "electron": "43.1.1",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "fontkit": "^2.0.4",
    "playwright": "^1.61.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.1.0"
  },
  "build": {
    "appId": "ai.board.desktop",
    "productName": "Board AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
